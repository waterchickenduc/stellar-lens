# ─────────────────────────────────────────
#  Stellar Dashboard — .env.example
#  Copy to .env and fill in your values:
#    cp .env.example .env
# ─────────────────────────────────────────

# ── Server ────────────────────────────────
PORT=3000

# ── Security ──────────────────────────────
# Generate a secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_me_to_something_long_and_random
JWT_EXPIRES_IN=7d

# ── Admin Account ─────────────────────────
# On every restart, this account is created or updated in the DB
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password

# ── Database ──────────────────────────────
DB_PATH=/app/data/stellar.db

# ── SMTP — leave blank to disable email ───
SMTP_HOST=smtp.strato.de
SMTP_PORT=465
SMTP_USER=mail@example.com
SMTP_PASS=longasspassword
SMTP_FROM=mail@example.com

# ── App ───────────────────────────────────
# Your VPS public URL (used in email links)
APP_URL=http://localhost:8080